# ============================================
#  LuxeDrive — Root .gitignore
#  NEVER commit secrets or bulky dependencies
# ============================================

# --- SECRETS (CRITICAL — never push these) ---
.env
.env.*
!.env.example

# --- Node dependencies ---
node_modules/
backend/node_modules/
frontend/node_modules/

# --- Frontend build output ---
frontend/dist/
frontend/dist-ssr/

# --- Logs ---
*.log
npm-debug.log*
yarn-debug.log*
lerna-debug.log*

# --- OS junk ---
.DS_Store
Thumbs.db
desktop.ini

# --- Editor ---
.vscode/
.idea/
*.suo
*.sw?

# --- PM2 (server only) ---
.pm2/

# --- Misc ---
*.local
